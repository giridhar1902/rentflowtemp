{
  "name": "mobile-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node ./scripts/check-bundle-budget.mjs",
    "build:mobile": "npm run build",
    "mobile:copy": "npm run build:mobile && npx cap copy",
    "mobile:sync": "npm run build:mobile && npx cap sync",
    "mobile:add:android": "npx cap add android",
    "mobile:add:ios": "npx cap add ios",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "mobile:doctor": "npx cap doctor",
    "preview": "vite preview",
    "check:ui-guardrails": "node ./scripts/check-ui-guardrails.mjs",
    "check:bundle-budget": "node ./scripts/check-bundle-budget.mjs",
    "visual:baseline:check": "vitest run src/visual/routeVisualBaseline.test.tsx",
    "visual:baseline:update": "vitest run src/visual/routeVisualBaseline.test.tsx --update",
    "lint": "npm run check:ui-guardrails && eslint . --ext ts,tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/push-notifications": "^8.0.1",
    "@headlessui/react": "^2.2.9",
    "@react-google-maps/api": "^2.20.8",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.74.7",
    "@types/google.maps": "^3.58.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "6.22.1",
    "recharts": "2.12.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
