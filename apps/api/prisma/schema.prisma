generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  LANDLORD
  TENANT
  ADMIN
}

enum PropertyOwnership {
  SELF_OWNED
  MANAGED
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum UnitStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  TERMINATED
  EXPIRED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELED
}

enum ChargeStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  REQUIRES_REVIEW
}

enum OfflineRentPaymentStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum PaymentMethodType {
  CARD
  BANK_TRANSFER
  CASH
  OTHER
}

enum ExpenseCategory {
  MAINTENANCE
  TAX
  UTILITIES
  INSURANCE
  OTHER
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum MaintenanceStatus {
  SUBMITTED
  REVIEWING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
}

enum DocumentType {
  LEASE
  PROPERTY_DEED
  RENT_RECEIPT
  MAINTENANCE_PHOTO
  OTHER
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_RECEIVED
  MAINTENANCE_UPDATE
  CHAT_MESSAGE
  LEASE_UPDATE
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
  SMS
}

enum PushPlatform {
  ANDROID
  IOS
  WEB
}

enum UtilityType {
  ELECTRICITY
  WATER
  INTERNET
  OTHER
}

enum UtilitySplitMethod {
  PER_TENANT
  PER_UNIT
  MANUAL
}

enum RentSplitMode {
  EQUAL
  MANUAL
}

model User {
  id                String     @id @default(cuid())
  authUserId        String     @unique
  email             String?    @unique
  role              UserRole
  firstName         String?
  lastName          String?
  phone             String?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  landlordProfile   LandlordProfile?
  tenantProfile     TenantProfile?
  propertiesOwned   Property[]            @relation("PropertyOwner")
  leasesAsLandlord  Lease[]               @relation("LeaseLandlord")
  leasesAsTenant    Lease[]               @relation("LeaseTenant")
  invitationsSent   TenantInvitation[]    @relation("InvitationInviter")
  invitationsRecv   TenantInvitation[]    @relation("InvitationInvitee")
  chargesCreated    RentCharge[]          @relation("ChargeCreator")
  payments          Payment[]             @relation("PaymentPayer")
  offlineRentPayments OfflineRentPayment[]
  paymentMethods    PaymentMethod[]
  expensesCreated   Expense[]             @relation("ExpenseCreator")
  maintenanceReqs   MaintenanceRequest[]  @relation("MaintenanceRequester")
  maintenanceNotes  MaintenanceComment[]
  threadMembers     ChatThreadParticipant[]
  messagesSent      ChatMessage[]
  documentsUploaded Document[]
  notifications     Notification[]
  pushDevices       PushDevice[]
  auditLogs         AuditLog[]            @relation("AuditActor")
  tenantRecords     Tenant[]

  @@index([role, isActive])
}

model LandlordProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TenantProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  emergencyContactName String?
  emergencyContactPhone String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id          String            @id @default(cuid())
  ownerId     String
  name        String
  propertyType String
  floors      Int?
  totalUnits  Int?
  amenities   String[]          @default([])
  status      PropertyStatus    @default(ACTIVE)
  ownership   PropertyOwnership @default(SELF_OWNED)
  addressLine1 String
  addressLine2 String?
  city        String
  state       String
  postalCode  String
  country     String            @default("US")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  owner               User                @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  units               Unit[]
  leases              Lease[]
  invitations         TenantInvitation[]
  expenses            Expense[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]
  chatThreads         ChatThread[]
  offlineRentPayments OfflineRentPayment[]
  utilities           Utility[]

  @@index([ownerId, status])
}

model Unit {
  id                String    @id @default(cuid())
  propertyId        String
  name              String
  floor             String?
  meterNumber       String?
  bedrooms          Int       @default(0)
  bathrooms         Int       @default(0)
  occupancy         Int       @default(1)
  furnishing        String?
  status            UnitStatus @default(VACANT)
  monthlyRent       Decimal   @db.Decimal(12, 2)
  securityDeposit   Decimal?  @db.Decimal(12, 2)
  maintenanceFee    Decimal?  @db.Decimal(12, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  property            Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases              Lease[]
  invitations         TenantInvitation[]
  maintenanceRequests MaintenanceRequest[]
  offlineRentPayments OfflineRentPayment[]
  beds                Bed[]
  tenants             Tenant[]
  utilities           Utility[]

  @@unique([propertyId, name])
  @@index([propertyId, status])
}

model Bed {
  id        String   @id @default(cuid())
  unitId    String
  label     String
  tenantId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit   Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation("BedTenant")

  @@unique([unitId, label])
}

model Tenant {
  id          String   @id @default(cuid())
  userId      String?
  unitId      String
  bedId       String?  @unique
  name        String
  phone       String?
  rentAmount  Decimal? @db.Decimal(12, 2)
  splitMode   RentSplitMode @default(EQUAL)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  unit          Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  bed           Bed?           @relation("BedTenant", fields: [bedId], references: [id], onDelete: SetNull)
  utilitySplits UtilitySplit[]
}

model Utility {
  id           String             @id @default(cuid())
  propertyId   String
  unitId       String?
  type         UtilityType
  billingMonth String
  amount       Decimal            @db.Decimal(12, 2)
  splitMethod  UtilitySplitMethod
  description  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  splits   UtilitySplit[]

  @@index([propertyId, billingMonth])
}

model UtilitySplit {
  id        String   @id @default(cuid())
  utilityId String
  tenantId  String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  utility Utility @relation(fields: [utilityId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([utilityId, tenantId])
}

model Lease {
  id                     String      @id @default(cuid())
  propertyId             String
  unitId                 String
  landlordId             String
  tenantId               String
  status                 LeaseStatus @default(DRAFT)
  startDate              DateTime
  endDate                DateTime
  monthlyRent            Decimal     @db.Decimal(12, 2)
  securityDeposit        Decimal?    @db.Decimal(12, 2)
  dueDay                 Int
  partialPaymentsAllowed Boolean     @default(false)
  cashPaymentsAllowed    Boolean     @default(false)
  cashApprovalRequired   Boolean     @default(true)
  autoRemindersEnabled   Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  property            Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit                Unit                @relation(fields: [unitId], references: [id], onDelete: Cascade)
  landlord            User                @relation("LeaseLandlord", fields: [landlordId], references: [id], onDelete: Restrict)
  tenant              User                @relation("LeaseTenant", fields: [tenantId], references: [id], onDelete: Restrict)
  tenantInvitations   TenantInvitation[]
  charges             RentCharge[]
  expenses            Expense[]
  maintenanceRequests MaintenanceRequest[]
  chatThreads         ChatThread[]
  documents           Document[]

  @@index([propertyId, status])
  @@index([tenantId, status])
  @@index([landlordId, status])
}

model TenantInvitation {
  id            String           @id @default(cuid())
  propertyId    String?
  unitId        String?
  leaseId       String?
  invitedById   String
  inviteeUserId String?
  inviteeEmail  String
  code          String           @unique
  status        InvitationStatus @default(PENDING)
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit       Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  lease      Lease?    @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  invitedBy  User      @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Restrict)
  invitee    User?     @relation("InvitationInvitee", fields: [inviteeUserId], references: [id], onDelete: SetNull)

  @@index([status, expiresAt])
}

model RentCharge {
  id               String      @id @default(cuid())
  leaseId          String
  createdById      String?
  periodStart      DateTime
  periodEnd        DateTime
  dueDate          DateTime
  baseRentAmount   Decimal     @db.Decimal(12, 2)
  maintenanceAmount Decimal    @default(0) @db.Decimal(12, 2)
  utilityAmount    Decimal     @default(0) @db.Decimal(12, 2)
  lateFeeAmount    Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal     @db.Decimal(12, 2)
  balanceAmount    Decimal     @db.Decimal(12, 2)
  status           ChargeStatus @default(ISSUED)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  lease     Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("ChargeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  payments  Payment[]

  @@index([leaseId, dueDate, status])
  @@unique([leaseId, periodStart, periodEnd])
}

model PaymentMethod {
  id           String            @id @default(cuid())
  userId       String
  type         PaymentMethodType
  provider     String?
  providerRef  String?
  last4        String?
  brand        String?
  isDefault    Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([userId, isDefault])
}

model Payment {
  id                String        @id @default(cuid())
  chargeId          String?
  payerId           String?
  methodId          String?
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  provider          String?
  providerPaymentId String?
  reference         String?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  charge  RentCharge?    @relation(fields: [chargeId], references: [id], onDelete: SetNull)
  payer   User?          @relation("PaymentPayer", fields: [payerId], references: [id], onDelete: SetNull)
  method  PaymentMethod? @relation(fields: [methodId], references: [id], onDelete: SetNull)
  events  PaymentEvent[]

  @@index([chargeId, status])
  @@index([payerId, status])
}

model OfflineRentPayment {
  id          String                   @id @default(cuid())
  tenantId    String
  propertyId  String
  unitId      String
  amount      Decimal                  @db.Decimal(12, 2)
  rentMonth   String                   // e.g. "November 2023"
  paymentDate DateTime
  paymentMode String                   // "UPI", "CASH", "BANK", "OTHER"
  proofUrl    String?
  status      OfflineRentPaymentStatus @default(PENDING_APPROVAL)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  tenant   User     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([propertyId, status])
  @@index([tenantId, status])
}

model PaymentEvent {
  id        String   @id @default(cuid())
  paymentId String
  externalEventId String? @unique
  eventType String
  payload   Json?
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
}

model Expense {
  id          String          @id @default(cuid())
  propertyId  String
  leaseId     String?
  createdById String?
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  incurredAt  DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  lease     Lease?   @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([propertyId, incurredAt])
}

model MaintenanceRequest {
  id            String             @id @default(cuid())
  propertyId    String
  unitId        String?
  leaseId       String?
  requesterId   String
  title         String
  category      String
  details       String
  priority      MaintenancePriority @default(MEDIUM)
  status        MaintenanceStatus   @default(SUBMITTED)
  emergency     Boolean             @default(false)
  submittedAt   DateTime            @default(now())
  scheduledAt   DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  property   Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit       Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  lease      Lease?              @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  requester  User                @relation("MaintenanceRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  comments   MaintenanceComment[]
  documents  Document[]

  @@index([propertyId, status, priority])
  @@index([requesterId, submittedAt])
}

model MaintenanceComment {
  id        String   @id @default(cuid())
  requestId String
  authorId  String
  comment   String
  createdAt DateTime @default(now())

  request MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User               @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

model ChatThread {
  id         String   @id @default(cuid())
  propertyId String?
  leaseId    String?
  title      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property     Property?              @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  lease        Lease?                 @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  participants ChatThreadParticipant[]
  messages     ChatMessage[]

  @@index([propertyId])
  @@index([leaseId])
}

model ChatThreadParticipant {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  joinedAt  DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model ChatMessage {
  id          String      @id @default(cuid())
  threadId    String
  senderId    String
  messageType MessageType @default(TEXT)
  content     String
  metadata    Json?
  createdAt   DateTime    @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User       @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Document {
  id                   String       @id @default(cuid())
  uploadedById         String
  propertyId           String?
  leaseId              String?
  maintenanceRequestId String?
  type                 DocumentType
  storagePath          String
  fileName             String
  mimeType             String
  sizeBytes            Int
  createdAt            DateTime     @default(now())

  uploadedBy         User                @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  property           Property?           @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  lease              Lease?              @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id], onDelete: SetNull)

  @@index([uploadedById, createdAt])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model PushDevice {
  id          String       @id @default(cuid())
  userId      String
  platform    PushPlatform
  token       String       @unique
  deviceName  String?
  appVersion  String?
  lastSeenAt  DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  entityType String
  entityId  String
  action    String
  requestId String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}
