  "dependencies": {
    "@nestjs/common": "^11.0.16",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.16",
    "@nestjs/platform-express": "^11.0.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.5.0",
    "@sentry/node": "^8.55.0",
    "@supabase/supabase-js": "^2.97.0",
    "axios": "^1.13.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^5.2.1",
    "jose": "^5.9.6",
    "pdf-lib": "^1.17.1",
    "razorpay": "^2.9.6",
